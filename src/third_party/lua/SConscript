    'lstring.c', 'lstrlib.c', 'ltable.c', 'ltablib.c', 'ltm.c',
    'lundump.c', 'lutf8lib.c', 'lvm.c', 'lzio.c',
]

objs = DefineGroup(
    'VibeBoard_Lua55',
    [File(source) for source in sources],
    depend=[],
    CPPPATH=[cwd],
    LOCAL_CCFLAGS=' -DLUA_USE_C89 -DCONFIG_LUA_MAXSTACK=8192',
