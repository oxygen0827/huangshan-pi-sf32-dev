{
  "schemaVersion": 1,
  "kind": "huangshan-runtime-app-manifest",
  "id": "clock_test",
  "name": "Clock Test",
  "description": "Runtime app package installed over serial.",
  "category": "Tools",
  "icon": "clock",
  "author": "Huangshan Runtime Team",
  "screenshot": "generated:clock_test",
  "requirements": ["Runtime", "Clock", "Serial or BLE install"],
  "entry": "main.lua",
  "components": [
    {
      "type": "clock",
      "capability": "clock",
      "label": "Clock",
      "value": "--:--:--"
    },
    {
      "type": "status",
      "capability": "status",
      "label": "Delivery",
      "value": "serial-msh"
    }
  ]
}
