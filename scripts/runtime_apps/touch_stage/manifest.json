{
  "schemaVersion": 1,
  "kind": "huangshan-runtime-app-manifest",
  "id": "touch_stage",
  "name": "Touch Stage",
  "description": "A compact stage for live Runtime touch state.",
  "category": "Hardware",
  "icon": "hand",
  "author": "Huangshan Runtime Team",
  "screenshot": "generated:touch_stage",
  "requirements": ["Runtime", "FT6146 touch", "Gesture API"],
  "entry": "main.lua",
  "components": [
    {
      "type": "status",
      "capability": "touch.count",
      "label": "Touches",
      "value": "0"
    },
    {
      "type": "status",
      "capability": "touch.gesture",
      "label": "Gesture",
      "value": "none"
    },
    {
      "type": "status",
      "capability": "touch.delta",
      "label": "Delta",
      "value": "0,0"
    },
    {
      "type": "status",
      "capability": "touch.duration",
      "label": "Hold",
      "value": "0ms"
    }
  ]
}
